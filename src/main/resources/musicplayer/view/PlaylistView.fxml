<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="270.0"
      spacing="12.0"
      styleClass="sidebar"
      stylesheets="@music-playlist-manager.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.musicplayer.controller.PlaylistController">

    <padding>
        <Insets bottom="18.0" left="18.0" right="14.0" top="18.0"/>
    </padding>

    <Label text="Playlists" styleClass="section-title"/>

    <ListView fx:id="playlistListView"
              VBox.vgrow="ALWAYS"/>

    <HBox spacing="8.0">
        <Button text="New"
                maxWidth="Infinity"
                HBox.hgrow="ALWAYS"
                onAction="#handleNewPlaylist"/>

        <Button text="Rename"
                maxWidth="Infinity"
                HBox.hgrow="ALWAYS"
                onAction="#handleRenamePlaylist"/>
    </HBox>

    <Button text="Delete selected playlist"
            maxWidth="Infinity"
            styleClass="danger-button"
            onAction="#handleDeletePlaylist"/>

    <Separator/>

    <Label text="Smart playlists" styleClass="section-title"/>

    <Button text="Generate by genre"
            maxWidth="Infinity"
            onAction="#handleGenerateByGenre"/>

    <Button text="Generate by year"
            maxWidth="Infinity"
            onAction="#handleGenerateByYear"/>

    <Button text="Generate by tag"
            maxWidth="Infinity"
            onAction="#handleGenerateByTag"/>

    <Separator />
    <Label styleClass="section-title" text="Trash" />
    <Button fx:id="openTrashButton" maxWidth="Infinity" onAction="#handleOpenTrash" text="Open Trash Bin" />

</VBox>

