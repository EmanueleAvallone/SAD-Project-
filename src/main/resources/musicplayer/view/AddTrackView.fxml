<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="620.0"
            prefWidth="900.0"
            styleClass="app-root"
            stylesheets="@music-playlist-manager.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.musicplayer.controller.AddTrackController">

    <top>
        <VBox spacing="4.0" styleClass="header">
            <padding>
                <Insets top="18.0" right="24.0" bottom="14.0" left="24.0"/>
            </padding>

            <Label text="Music Player" styleClass="app-title"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="18.0" styleClass="card">
            <padding>
                <Insets top="20.0" right="24.0" bottom="20.0" left="24.0"/>
            </padding>

            <Label fx:id="formTitleLabel" text="Add track" styleClass="section-title"/>
            <GridPane hgap="18.0" vgap="16.0">

                <Label text="Title" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="titleField"
                           promptText="Track title"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Author" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="authorField"
                           promptText="Author"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="Length" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="lengthField"
                           promptText="e.g. 3:45 or 225 seconds"
                           maxWidth="250.0"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                <Label text="Genre" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="genreField"
                           promptText="Genre"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <Label text="Year" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="yearField"
                           promptText="e.g. 2024"
                           maxWidth="250.0"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <Label text="Audio file"
                       GridPane.rowIndex="5"
                       GridPane.columnIndex="0"/>

                <HBox spacing="8.0"
                      GridPane.rowIndex="5"
                      GridPane.columnIndex="1">
                    <TextField fx:id="audioFilePathField"
                               promptText="No audio file selected"
                               editable="false"
                               HBox.hgrow="ALWAYS"/>

                    <Button text="Choose file"
                            onAction="#handleChooseAudioFile"/>
                </HBox>

                <Label text="Notes / Description (optional)"
                       GridPane.rowIndex="6"
                       GridPane.columnIndex="0"/>

                <TextArea fx:id="notesArea"
                          styleClass="notes-area"
                          prefHeight="130.0"
                          promptText="Optional notes..."
                          wrapText="true"
                          GridPane.rowIndex="6"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <VBox spacing="8.0">
                <Label text="Visual tags" styleClass="field-label"/>

                <HBox spacing="70.0" styleClass="card">
                    <padding>
                        <Insets top="10.0" right="14.0" bottom="10.0" left="14.0"/>
                    </padding>

                    <CheckBox fx:id="favouriteCheckBox" text="Favourite"/>
                    <CheckBox fx:id="explicitCheckBox" text="Explicit"/>
                    <CheckBox fx:id="newReleaseCheckBox" text="New release"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="footer">
            <padding>
                <Insets top="12.0" right="18.0" bottom="12.0" left="18.0"/>
            </padding>

            <Label fx:id="statusLabel" text="Ready"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Import from file" onAction="#handleImport"/>
            <Button text="Reset" onAction="#handleReset"/>
            <Button text="Cancel" onAction="#handleCancel"/>
            <Button fx:id="submitButton" text="Add track" onAction="#handleAddTrack"/>
        </HBox>
    </bottom>

</BorderPane>