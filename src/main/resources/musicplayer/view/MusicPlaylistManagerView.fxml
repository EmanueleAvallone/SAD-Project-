<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            minWidth="980.0"
            minHeight="620.0"
            prefWidth="1280.0"
            prefHeight="760.0"
            styleClass="app-root"
            stylesheets="@music-playlist-manager.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.musicplayer.controller.MainController">

    <top>
        <VBox spacing="8.0" styleClass="header">
            <padding>
                <Insets bottom="14.0" left="22.0" right="22.0" top="18.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="app-title" text="Music Playlist Manager"/>
                    <Label styleClass="subtitle"
                           text="Create playlists, manage tracks, simulate playback and apply advanced filters"
                           wrapText="true"/>
                </VBox>

                <TextField fx:id="searchField"
                           minWidth="180.0"
                           prefWidth="340.0"
                           maxWidth="420.0"
                           promptText="Search tracks, artists, playlists..."/>

                <Button fx:id="clearSearchButton"
                        onAction="#handleClearSearch"
                        text="Clear"/>
            </HBox>
        </VBox>
    </top>

    <left>
        <fx:include fx:id="playlistSection"
                    source="PlaylistView.fxml"/>
    </left>

    <center>
        <SplitPane dividerPositions="0.52"
                   orientation="VERTICAL"
                   styleClass="content-split"
                   minWidth="0.0">

            <items>
                <VBox spacing="10.0" styleClass="card" minWidth="0.0">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10.0" minWidth="0.0">
                        <Label styleClass="section-title" text="Track library"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button fx:id="addTrackButton"
                                onAction="#handleAddTrack"
                                text="Add track"/>

                        <Button fx:id="editTrackButton"
                                onAction="#handleEditTrack"
                                text="Edit"/>

                        <Button fx:id="deleteTrackButton"
                                onAction="#handleDeleteTrack"
                                styleClass="danger-button"
                                text="Delete"/>
                    </HBox>

                    <TableView fx:id="trackTableView"
                               minHeight="160.0"
                               VBox.vgrow="ALWAYS">
                        <placeholder>
                            <Label text="No tracks yet. Add a track to start."/>
                        </placeholder>

                        <columns>
                            <TableColumn fx:id="trackTitleColumn" prefWidth="190.0" text="Title"/>
                            <TableColumn fx:id="trackAuthorColumn" prefWidth="160.0" text="Author"/>
                            <TableColumn fx:id="trackLengthColumn" prefWidth="80.0" text="Length"/>
                            <TableColumn fx:id="trackGenreColumn" prefWidth="120.0" text="Genre"/>
                            <TableColumn fx:id="trackYearColumn" prefWidth="70.0" text="Year"/>
                            <TableColumn fx:id="trackTagsColumn" prefWidth="170.0" text="Tags"/>
                            <TableColumn fx:id="trackPlayCountColumn" prefWidth="80.0" text="Played"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="10.0" styleClass="card" minWidth="0.0">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10.0" minWidth="0.0">
                        <Label fx:id="selectedPlaylistTitleLabel"
                               styleClass="section-title"
                               text="Selected playlist"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button fx:id="addToPlaylistButton"
                                onAction="#handleAddToPlaylist"
                                text="Add selected track"/>

                        <Button fx:id="removeFromPlaylistButton"
                                onAction="#handleRemoveFromPlaylist"
                                text="Remove"/>

                        <Button fx:id="moveTrackUpButton"
                                onAction="#handleMoveTrackUp"
                                text="Move up"/>

                        <Button fx:id="moveTrackDownButton"
                                onAction="#handleMoveTrackDown"
                                text="Move down"/>
                    </HBox>

                    <TableView fx:id="playlistTrackTableView"
                               minHeight="150.0"
                               VBox.vgrow="ALWAYS">
                        <placeholder>
                            <Label text="Select a playlist or add tracks to it."/>
                        </placeholder>

                        <columns>
                            <TableColumn fx:id="playlistTrackOrderColumn" prefWidth="55.0" text="#"/>
                            <TableColumn fx:id="playlistTrackTitleColumn" prefWidth="230.0" text="Title"/>
                            <TableColumn fx:id="playlistTrackAuthorColumn" prefWidth="170.0" text="Author"/>
                            <TableColumn fx:id="playlistTrackLengthColumn" prefWidth="90.0" text="Length"/>
                            <TableColumn fx:id="playlistTrackGenreColumn" prefWidth="120.0" text="Genre"/>
                        </columns>
                    </TableView>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <right>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    minWidth="280.0"
                    prefWidth="315.0"
                    maxWidth="370.0"
                    styleClass="right-scroll-pane">

            <content>
                <VBox minWidth="280.0"
                      prefWidth="315.0"
                      maxWidth="370.0"
                      spacing="14.0"
                      styleClass="right-panel">
                    <padding>
                        <Insets bottom="18.0" left="14.0" right="18.0" top="18.0"/>
                    </padding>

                    <fx:include fx:id="playerControl" source="PlayerControllerView.fxml"/>

                    <VBox spacing="10.0" styleClass="card">
                        <padding>
                            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
                        </padding>

                        <Label styleClass="section-title" text="Advanced filters"/>

                        <TextField fx:id="filterTextField" promptText="Title or author"/>

                        <ComboBox fx:id="genreComboBox"
                                  maxWidth="Infinity"
                                  promptText="Genre"/>

                        <HBox spacing="8.0">
                            <TextField fx:id="yearFromField"
                                       promptText="Year from"
                                       HBox.hgrow="ALWAYS"/>

                            <TextField fx:id="yearToField"
                                       promptText="Year to"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Label styleClass="field-label" text="Visual tags"/>

                        <VBox spacing="5.0">
                            <CheckBox fx:id="favouriteTagCheckBox" text="Favourite"/>
                            <CheckBox fx:id="explicitTagCheckBox" text="Explicit"/>
                            <CheckBox fx:id="newReleaseTagCheckBox" text="New release"/>
                        </VBox>

                        <HBox spacing="8.0">
                            <Button fx:id="applyFiltersButton"
                                    maxWidth="Infinity"
                                    onAction="#handleApplyFilters"
                                    text="Apply"
                                    HBox.hgrow="ALWAYS"/>

                            <Button fx:id="resetFiltersButton"
                                    maxWidth="Infinity"
                                    onAction="#handleResetFilters"
                                    text="Reset"
                                    HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="10.0" styleClass="card" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="section-title" text="Most played tracks"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button fx:id="playMostPlayedButton"
                                    onAction="#handlePlayMostPlayed"
                                    text="Play all"/>
                        </HBox>

                        <StackPane minHeight="180.0"
                                   prefHeight="260.0"
                                   VBox.vgrow="ALWAYS">
                            <ScrollPane fx:id="mostPlayedScrollPane"
                                        fitToWidth="true"
                                        vbarPolicy="AS_NEEDED"
                                        hbarPolicy="NEVER"
                                        style="-fx-background-color: transparent;">
                                <content>
                                    <VBox fx:id="topTracksContainer"
                                          spacing="8.0"
                                          alignment="TOP_CENTER"/>
                                </content>
                            </ScrollPane>

                            <VBox fx:id="emptyMostPlayedView"
                                  alignment="CENTER"
                                  spacing="5.0"
                                  visible="false">
                                <Label text="No songs playing"
                                       style="-fx-font-weight: bold; -fx-text-fill: gray;"/>

                                <Label text="Play a song to get started"
                                       style="-fx-font-size: 11px; -fx-text-fill: darkgray;"/>
                            </VBox>
                        </StackPane>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </right>

    <bottom>
        <VBox spacing="6.0">
            <HBox fx:id="undoSnackbar"
                  alignment="CENTER_LEFT"
                  managed="false"
                  visible="false"
                  spacing="12.0"
                  style="-fx-background-color: #323232; -fx-padding: 10 18 10 18;">

                <Label fx:id="snackbarMessageLabel"
                       text="Elemento rimosso"
                       textFill="WHITE"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="snackbarUndoButton"
                        onAction="#handleSnackbarUndo"
                        text="Annulla"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="footer">
                <padding>
                    <Insets bottom="12.0" left="18.0" right="18.0" top="12.0"/>
                </padding>

                <Label fx:id="statusLabel" text="Ready"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="undoButton"
                        onAction="#handleUndo"
                        text="Undo">
                    <tooltip>
                        <Tooltip text="Undo add/remove operations"/>
                    </tooltip>
                </Button>

                <Button fx:id="redoButton"
                        onAction="#handleRedo"
                        text="Redo"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>