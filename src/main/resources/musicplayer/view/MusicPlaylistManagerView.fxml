<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>


<BorderPane fx:id="rootPane" prefHeight="760.0" prefWidth="1280.0" styleClass="app-root" stylesheets="@music-playlist-manager.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.musicplayer.controller.MainController">

    <top>
        <VBox spacing="8.0" styleClass="header">
            <padding>
                <Insets bottom="14.0" left="22.0" right="22.0" top="18.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <VBox spacing="2.0">
                    <Label styleClass="app-title" text="Music Playlist Manager" />
                    <Label styleClass="subtitle" text="Create playlists, manage tracks, simulate playback and apply advanced filters" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="globalSearchField" prefWidth="340.0" promptText="Search tracks, artists, playlists..." />
                <Button fx:id="clearSearchButton" onAction="#handleClearSearch" text="Clear" />
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="270.0" spacing="12.0" styleClass="sidebar">
            <padding>
                <Insets bottom="18.0" left="18.0" right="14.0" top="18.0" />
            </padding>

            <Label styleClass="section-title" text="Playlists" />
            <ListView fx:id="playlistListView" VBox.vgrow="ALWAYS" />

            <HBox spacing="8.0">
                <Button fx:id="newPlaylistButton" maxWidth="Infinity" onAction="#handleNewPlaylist" text="New" HBox.hgrow="ALWAYS" />
                <Button fx:id="renamePlaylistButton" maxWidth="Infinity" onAction="#handleRenamePlaylist" text="Rename" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button fx:id="deletePlaylistButton" maxWidth="Infinity" onAction="#handleDeletePlaylist" styleClass="danger-button" text="Delete selected playlist" />

            <Separator />

            <Label styleClass="section-title" text="Smart playlists" />
            <Button fx:id="generateByGenreButton" maxWidth="Infinity" onAction="#handleGenerateByGenre" text="Generate by genre" />
            <Button fx:id="generateByYearButton" maxWidth="Infinity" onAction="#handleGenerateByYear" text="Generate by year" />
            <Button fx:id="generateByTagButton" maxWidth="Infinity" onAction="#handleGenerateByTag" text="Generate by tag" />
        </VBox>
    </left>

    <center>
        <SplitPane dividerPositions="0.52" orientation="VERTICAL" styleClass="content-split">
            <items>
                <VBox spacing="10.0" styleClass="card">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label styleClass="section-title" text="Track library" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="addTrackButton" onAction="#handleAddTrack" text="Add track" />
                        <Button fx:id="editTrackButton" onAction="#handleEditTrack" text="Edit" />
                        <Button fx:id="deleteTrackButton" onAction="#handleDeleteTrack" styleClass="danger-button" text="Delete" />
                    </HBox>
                    <TableView fx:id="trackTableView" VBox.vgrow="ALWAYS">
                        <placeholder>
                            <Label text="No tracks yet. Add a track to start." />
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="trackTitleColumn" prefWidth="180.0" text="Title" />
                            <TableColumn fx:id="trackAuthorColumn" prefWidth="155.0" text="Author" />
                            <TableColumn fx:id="trackLengthColumn" prefWidth="90.0" text="Length" />
                            <TableColumn fx:id="trackGenreColumn" prefWidth="110.0" text="Genre" />
                            <TableColumn fx:id="trackYearColumn" prefWidth="80.0" text="Year" />
                            <TableColumn fx:id="trackTagsColumn" prefWidth="170.0" text="Tags" />
                            <TableColumn fx:id="trackPlayCountColumn" prefWidth="95.0" text="Played" />
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="10.0" styleClass="card">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label fx:id="selectedPlaylistTitleLabel" styleClass="section-title" text="Selected playlist" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="addToPlaylistButton" onAction="#handleAddToPlaylist" text="Add selected track" />
                        <Button fx:id="removeFromPlaylistButton" onAction="#handleRemoveFromPlaylist" text="Remove" />
                        <Button fx:id="moveTrackUpButton" onAction="#handleMoveTrackUp" text="Move up" />
                        <Button fx:id="moveTrackDownButton" onAction="#handleMoveTrackDown" text="Move down" />
                    </HBox>
                    <TableView fx:id="playlistTrackTableView" VBox.vgrow="ALWAYS">
                        <placeholder>
                            <Label text="Select a playlist or add tracks to it." />
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="playlistTrackOrderColumn" prefWidth="55.0" text="#" />
                            <TableColumn fx:id="playlistTrackTitleColumn" prefWidth="210.0" text="Title" />
                            <TableColumn fx:id="playlistTrackAuthorColumn" prefWidth="170.0" text="Author" />
                            <TableColumn fx:id="playlistTrackLengthColumn" prefWidth="90.0" text="Length" />
                            <TableColumn fx:id="playlistTrackGenreColumn" prefWidth="120.0" text="Genre" />
                            <TableColumn fx:id="playlistTrackTagsColumn" prefWidth="190.0" text="Tags" />
                        </columns>
                    </TableView>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <right>
        <VBox prefWidth="315.0" spacing="14.0" styleClass="right-panel">
            <padding>
                <Insets bottom="18.0" left="14.0" right="18.0" top="18.0" />
            </padding>

            <fx:include fx:id="playerControl" source="PlayerControllerView.fxml" />

            <VBox spacing="10.0" styleClass="card">
                <padding>
                    <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                </padding>
                <Label styleClass="section-title" text="Advanced filters" />
                <TextField fx:id="filterTextField" promptText="Title or author" />
                <ComboBox fx:id="genreComboBox" maxWidth="Infinity" promptText="Genre" />
                <HBox spacing="8.0">
                    <TextField fx:id="yearFromField" promptText="Year from" HBox.hgrow="ALWAYS" />
                    <TextField fx:id="yearToField" promptText="Year to" HBox.hgrow="ALWAYS" />
                </HBox>
                <Label styleClass="field-label" text="Visual tags" />
                <VBox spacing="5.0">
                    <CheckBox fx:id="favouriteTagCheckBox" text="Favourite" />
                    <CheckBox fx:id="explicitTagCheckBox" text="Explicit" />
                    <CheckBox fx:id="newReleaseTagCheckBox" text="New release" />
                </VBox>
                <HBox spacing="8.0">
                    <Button fx:id="applyFiltersButton" maxWidth="Infinity" onAction="#handleApplyFilters" text="Apply" HBox.hgrow="ALWAYS" />
                    <Button fx:id="resetFiltersButton" maxWidth="Infinity" onAction="#handleResetFilters" text="Reset" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <VBox spacing="10.0" styleClass="card">
                <padding>
                    <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                </padding>
                <Label styleClass="section-title" text="Most played" />
                <ListView fx:id="mostPlayedListView" prefHeight="120.0" />
            </VBox>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="footer">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="12.0" />
            </padding>
            <Label fx:id="statusLabel" text="Ready" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="undoButton" onAction="#handleUndo" text="Undo">
                <tooltip>
                    <Tooltip text="Undo add/remove operations" />
                </tooltip>
            </Button>
            <Button fx:id="redoButton" onAction="#handleRedo" text="Redo" />
        </HBox>
    </bottom>

</BorderPane>
